{
  "name": "cc-statusbar",
  "displayName": "Claude/Codex Usage — Quota & Context Statusbar",
  "description": "See Claude Code and Codex quota, context, token-equivalent, and cache signals right in the VS Code status bar. Switch between Auto, Claude Code, and Codex from the hover menu.",
  "version": "1.0.16",
  "publisher": "solux-dev",
  "license": "MIT",
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "claude",
    "claude-code",
    "codex",
    "openai",
    "chatgpt",
    "anthropic",
    "quota",
    "rate-limit",
    "context-window",
    "tokens",
    "usage",
    "cache",
    "statusbar"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Solux-dev/cc-statusbar.git"
  },
  "homepage": "https://github.com/Solux-dev/cc-statusbar#readme",
  "bugs": {
    "url": "https://github.com/Solux-dev/cc-statusbar/issues"
  },
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "ccStatusbar.refresh",
        "title": "%ccStatusbar.cmd.refresh%"
      },
      {
        "command": "ccStatusbar.toggleQuota",
        "title": "%ccStatusbar.cmd.toggleQuota%"
      },
      {
        "command": "ccStatusbar.switchLanguage",
        "title": "%ccStatusbar.cmd.switchLanguage%"
      },
      {
        "command": "ccStatusbar.openPanel",
        "title": "%ccStatusbar.cmd.openPanel%"
      },
      {
        "command": "ccStatusbar.selectProvider",
        "title": "%ccStatusbar.cmd.selectProvider%"
      },
      {
        "command": "ccStatusbar.useAuto",
        "title": "%ccStatusbar.cmd.useAuto%"
      },
      {
        "command": "ccStatusbar.useClaude",
        "title": "%ccStatusbar.cmd.useClaude%"
      },
      {
        "command": "ccStatusbar.useCodex",
        "title": "%ccStatusbar.cmd.useCodex%"
      },
      {
        "command": "ccStatusbar.useLanguageAuto",
        "title": "%ccStatusbar.cmd.useLanguageAuto%"
      },
      {
        "command": "ccStatusbar.useLanguageEn",
        "title": "%ccStatusbar.cmd.useLanguageEn%"
      },
      {
        "command": "ccStatusbar.useLanguageRu",
        "title": "%ccStatusbar.cmd.useLanguageRu%"
      }
    ],
    "configuration": {
      "title": "Claude/Codex Usage — Quota & Context Statusbar",
      "properties": {
        "ccStatusbar.provider": {
          "type": "string",
          "enum": [
            "auto",
            "claude",
            "codex"
          ],
          "default": "auto",
          "description": "%ccStatusbar.cfg.provider%",
          "enumDescriptions": [
            "%ccStatusbar.cfg.provider.auto%",
            "%ccStatusbar.cfg.provider.claude%",
            "%ccStatusbar.cfg.provider.codex%"
          ]
        },
        "ccStatusbar.language": {
          "type": "string",
          "enum": [
            "auto",
            "en",
            "ru"
          ],
          "default": "auto",
          "description": "%ccStatusbar.cfg.language%",
          "enumDescriptions": [
            "%ccStatusbar.cfg.language.auto%",
            "English",
            "Русский"
          ]
        },
        "ccStatusbar.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show the status bar item."
        },
        "ccStatusbar.refreshSeconds": {
          "type": "number",
          "default": 10,
          "minimum": 3,
          "description": "How often (seconds) to re-read the session transcript and redraw."
        },
        "ccStatusbar.alignment": {
          "type": "string",
          "enum": [
            "left",
            "right"
          ],
          "default": "right",
          "description": "Status bar side."
        },
        "ccStatusbar.cacheReadWeight": {
          "type": "number",
          "default": 0.1,
          "description": "Weight of cache-read tokens in the token-equivalent metric (cache read ≈ 10% of a fresh input token). Keep in sync with tools/session-cost.py."
        },
        "ccStatusbar.cacheWriteWeight": {
          "type": "number",
          "default": 1.25,
          "description": "Weight of cache-write tokens in the token-equivalent metric (cache write ≈ 125%). Keep in sync with tools/session-cost.py."
        },
        "ccStatusbar.quota.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Claude Code: fetch real 5h/7d subscription quota from Anthropic (costs ~1 token per poll, only while active). Turn off to keep only local transcript metrics."
        },
        "ccStatusbar.quota.minPollSeconds": {
          "type": "number",
          "default": 300,
          "minimum": 60,
          "description": "Claude Code/Codex: minimum seconds between quota API calls (throttle to avoid rate-limit 429). Claude polling runs only while the session was recently active."
        },
        "ccStatusbar.credentialsPath": {
          "type": "string",
          "default": "",
          "description": "Override path to Claude credentials JSON (default: ~/.claude/.credentials.json)."
        },
        "ccStatusbar.codex.commandPath": {
          "type": "string",
          "default": "",
          "description": "%ccStatusbar.cfg.codex.commandPath%"
        },
        "ccStatusbar.context.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Claude Code: show how full the model's context window is right now (current input ÷ the model's max_input_tokens). The window limit is fetched once per model from the Anthropic Models API using the same local token as the quota feature and cached 24h; if it can't be fetched the % is hidden (never guessed)."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "node --test out/test/logic.test.js",
    "package": "npx --yes @vscode/vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0"
  }
}
